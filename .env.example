# =============================================================================
# All of these are OPTIONAL — the converter works in full passthrough mode
# by default, using whatever API key and model CC Switch sends.
# =============================================================================

# Optional: override API key. If not set, the Authorization header from
# CC Switch is forwarded directly to DeepSeek.
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Optional: if your DeepSeek endpoint differs from the default
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: converter listen address
# CONVERTER_PORT=11888
# CONVERTER_HOST=127.0.0.1

# Optional: model name mapping. If not set, model names pass through as-is
# (configure the DeepSeek model name directly in CC Switch).
# MODEL_MAP=gpt-5.5:deepseek-v4-pro,gpt-5.1:deepseek-chat
