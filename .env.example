# =============================================================================
# All of these are OPTIONAL — the converter works in full passthrough mode
# by default, using whatever API key and model CC Switch sends.
# =============================================================================

# --- Generic (recommended) ---
# Provider base URL. Supports any OpenAI Chat Completions compatible API.
# Default: https://api.deepseek.com
# PROVIDER_BASE_URL=https://api.deepseek.com

# Optional: override API key. If not set, the Authorization header from
# CC Switch is forwarded directly to the upstream provider.
# PROVIDER_API_KEY=sk-your-api-key

# --- Legacy (still works) ---
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# --- Converter listen address ---
# CONVERTER_PORT=11888
# CONVERTER_HOST=127.0.0.1

# --- Optional model name mapping ---
# Format: from:to,from:to
# MODEL_MAP=gpt-5.5:deepseek-chat,gpt-5.1:deepseek-chat

# =============================================================================
# Supported providers (anything OpenAI Chat Completions compatible):
# =============================================================================
# DeepSeek     https://api.deepseek.com
# 豆包/Doubao  https://ark.cn-beijing.volces.com/api/v3
# 通义千问     https://dashscope.aliyuncs.com/compatible-mode/v1
# Kimi/Moonshot https://api.moonshot.cn
# 智谱GLM      https://open.bigmodel.cn/api/paas/v4
# SiliconFlow  https://api.siliconflow.cn
# OpenRouter   https://openrouter.ai/api
# Ollama       http://localhost:11434
# vLLM         http://localhost:8000
